# Dependencies
# This ignores node_modules in the root, client, and server folders
node_modules/

# Environment Variables
# This ignores .env files anywhere in the project
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Production Build Files
# These can be large and are generated automatically
dist/
build/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Testing
coverage/

# OS Generated Files
# These are system files (like thumbnails) that shouldn't be uploaded
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / Editor folders
.idea/
.vscode/
*.swp
*.swo

# Optional npm cache
.npm

# Optional eslint cache
.eslintcache